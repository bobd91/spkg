pkgname=testpkg
pkgver=2.0.0
pkgrel=1

sources=(
        testpkg-2.0.0-1.tar.gz
        testpkg-lib1-2.0.0-1.tar.gz
        )
md5sums=(
        88375a8921a823721549273390b5cf23
        ba1a181707379574c1a0310c37941086
        )
replaces+=( testpkg-lib1 )

build() {
        cd "$pkgname-$pkgver"
        echo "Building $pkgname-$pkgver-$pkgrel"
        tar xvf ../testpkg-lib1-2.0.0-1.tar.gz --strip-components=1
}

package() {
        echo "Installing $pkgname-$pkgver-$pkgrel"
        cp -av {usr,etc} $pkgdir
}


