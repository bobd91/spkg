pkgname=testpkg2
pkgver=1.0.0
pkgrel=1

sources=(
        "testpkg2-1.0.0.tar.gz"
        )
md5sums=(
        TESTPKG_MD5SUM
        )

build() {
        cd "$pkgname-$pkgver"
        echo "Building $pkgname-$pkgver-$pkgrel"
}

package() {
        echo "Installing $pkgname-$pkgver-$pkgrel"
        cp -av usr $pkgdir
}
