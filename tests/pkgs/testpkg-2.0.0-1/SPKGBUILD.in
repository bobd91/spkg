pkgname=testpkg
pkgver=2.0.0
pkgrel=1

sources=(
        testpkg-2.0.0.tar.gz
        )
md5sums=(
        TESTPKG_MD5SUM
        )
replaces+=( testpkg-lib1 )

build() {
        cd "$pkgname-$pkgver"
        echo "build function for: $pkgname-$pkgver-$pkgrel"
}

package() {
        echo "package function for: $pkgname-$pkgver-$pkgrel"
        cp -a {usr,etc} $pkgdir
}


