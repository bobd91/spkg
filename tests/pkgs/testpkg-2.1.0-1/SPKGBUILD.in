pkgname=testpkg
pkgver=2.1.0
pkgrel=1

sources=(
        "testpkg-2.1.0.tar.gz"
        )
md5sums=(
        TESTPKG_MD5SUM
        )

build() {
        cd "$pkgname-$pkgver"
        echo "build function for: $pkgname-$pkgver-$pkgrel"
}

package() {
        echo "package function for: $pkgname-$pkgver-$pkgrel"
        cp -a {usr,etc} $pkgdir
}

pre_install() {
        echo "pre_install function: $*"
        echo "modifying /etc/testpkg.conf prior to installation"
        sed -i -e 's|\(.*\)|\1 - Modified|' "$sysroot/etc/testpkg.conf"
}

post_install() {
        echo "post_install function: $*"
}

pre_uninstall() {
        echo "pre_uninstall function: $*"
}

post_uninstall() {
        echo "post_uninstall function: $*"
}


