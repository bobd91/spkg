
.SILENT: install

install:
	install -d $(DESTDIR)SPKG_exec_prefix
	install -m 755 spkg $(DESTDIR)SPKG_exec_prefix
	install -d $(DESTDIR)SPKG_prefix/etc
	install -m 644 spkg.conf $(DESTDIR)SPKG_prefix/etc
	install -d $(DESTDIR)SPKG_prefix/usr/share/spkg
	install -m 644 spkg.bash $(DESTDIR)SPKG_prefix/usr/share/spkg
	install -d $(DESTDIR)SPKG_prefix/var/log/spkg
