#!/bin/env bash

# Simple Package Manager

# TODO: testing

# TODO: lfs2spkg 

# shellcheck disable=SC2164 # we shadow cd to check for failure
# shellcheck disable=SC1090,SC1091 # we source lots of user defined files

# configure replaces SPKG_... values
sysroot=SPKG_with_sysroot
prefix=SPKG_prefix
version=SPKG_version

# Error handling

set -E
trap abort SIGTERM

abort() {
        printf 'Aborting...\n' >&2
        exit 1
}

# Program failure
die() {
        local errno=$1
        local level=$2
        local levels=${#BASH_LINENO[@]}

        shift 2
        printf '%s returned %d in:\n' "$*" $errno >&2
        for (( level+=1 ; level<levels ; level++ )); do
                printf '%s: line %d: %s()\n' \
                        "${BASH_SOURCE[level]}" \
                        ${BASH_LINENO[level-1]} \
                        "${FUNCNAME[level]}" >&2
        done

        kill 0
}

die_if() {
        (( $1 != 0 )) || return
        die $1 1 "$@"
}

# User error
fail() {
        echo 'Failed:' "$@" >&2
        log '[Failed]' "$@"
        kill 0
}

# Try to run something, die if it fails
try() {
        "$@" || die $? 1 "$@"
}

# Try and trace output
trace() {
        "$@" >> "$tracefile" || die $? 1 "$@"
}

# Restore stdout/stderr and wait for children
# Due to race condition with teed output (see end of this file) 
cleanup() {
        local rc=$?
        #[[ $stdoutfd ]] && exec >&$stdoutfd
        #[[ $stderrfd ]] && exec 2>&$stderrfd
        wait
        return $rc
}

# Logging functions

info() {
        try echo "$*"
        log "[Info]" "$@"
}

warn() {
        try echo "Warning: $*"
        log "[Warning]" "$@" 
}

log() {
        local t
        try printf -v t '%(%F %T %z)T'
        try printf '[%s] %s\n' "$t" "$*" >> "$logfile"
}


# General utility functions

usage() {
        try echo "Usage: $(basename "$0") command arg"
        try echo "       $(basename "$0") --help"
}

source_file() { 
        pushd . > /dev/null
        try source "$@"
        popd > /dev/null
}


require() {
        declare -gA require_done
        local lib
        for lib; do
                [[ ! ${require_done[$lib]} ]] || continue
                source_file -p "$requirepath" "$lib.sh"
                require_done[$lib]=1
        done
}

call_fn() {
        [[ "$(type -t "$1")" == function ]] || return
        try "$@"
}

confirm () {
        try read -p "$1" -n 1 -r
        try echo
        [[ ${REPLY,,} =~ ^(|"$2")$ ]]
}

# Add $prefix to the front of each element of a PATH
prefix_path() {
        local sep dirs dir
        declare -g prefix

        [[ $prefix ]] || return

        readarray -d ':' -t dirs <<< "$1"

        for dir in "${dirs[@]}"; do
                printf '%s%s%s' "$sep" "$prefix" "$dir"
                sep=':'
        done
}


# Package utility functions

confirm_pkgs() {
        local prompt=${1:?}
        local def=${2:?}
        shift 2

        try printf "Selected packages:\n\n"
        try printf "%s\n\n" "$*"
        confirm "$prompt" "$def"
}

# confirm_pkgs displayed to stdout/stderr without writing to our logs
confirm_pkgs_nolog() {
        confirm_pkgs "$@" >&$stdoutfd >&$stderrfd
}

has_permission() {
        [[ -w "$installroot" ]]
}

parse_pkgspec() {
        [[ $1 =~ ^.+-([^-]+)-[0-9]+ ]]
}

pkgfiles() {
        local files
        shopt -s nullglob
        files=( "${1:?}"-[0-9][0-9\.-]* )
        shopt -u nullglob
        if (( ${#files[@]} )); then
                try printf '%s\n' "${files[@]}"
        fi
}

# Print package spec of installed version of <package name>
installed_pkg() {
        local pkgname=${1:?}
        local pkgspec="$installroot/$pkgname/.spkg/pkgspec"

        if [[ -f $pkgspec ]]; then
                try cat "$pkgspec"
        fi
}

# Success if <package spec> is installed
is_installed() {
        local pkgspec=${1:?}
        local pkgname="${pkgspec%-*-*}"

        [[ $pkgspec == "$(installed_pkg "$pkgname")" ]]
}

# Print package specs that match args sorted by name and version number
# If first argument is '-r' then reverse sort
versort() {
        local args='-V'

        # Using output of ls in scripts is problematic but we want to use version sorting
        # And package names shouldn't contain newlines and other odd characters
        if [[ $1 == '-r' ]]; then
                args+='r'
                shift
        fi

        try printf "%s\n" "$@" | try sort $args
}

# Print package spec of the <package name> with the highest version number
latest_pkg() {
        local pkgname=${1:?}
        declare -a tars

        # Extract package spec from full path listing of tar files
        # Latest version will be sorted to the bottom
        try readarray -t tars < <(pkgfiles "$pkgroot/$pkgname")
        if (( ${#tars[@]} )); then
                versort "${tars[@]}" | 
                        try tail -n 1 |
                        try sed -e "s|/\([^/]\+/\)*\(.*\)\-$pkgsuffix|\2|" 
        fi
}

# Move <pkgspec> build and tar file to oldroot
archive_pkg() {
        local pkgspec=${1:?}
        local pkgbuilddir pkgtarfile

        pkgbuilddir="$buildroot/$pkgspec"
        pkgtarfile="$pkgroot/$pkgspec-$pkgsuffix"

        if [[ -d "$pkgbuilddir" ]]; then
                try rm -rf "$oldroot/build/$pkgspec"
                trace mv -v "$pkgbuilddir" "$oldroot/build"
        fi

        if [[ -f "$pkgtarfile" ]]; then
                try rm -f "$oldroot/pkg/$pkgspec-$pkgsuffix"
                trace mv -v "$pkgtarfile" "$oldroot/pkg"
        fi
}

# Remove installed pkg directory
# Unfortunately rm -rv lists all of the removed files
# And we just want to record removed directory
rmpkgdir() {
        local pkgdir=${1:?}
        try rm -r "$installroot/$pkgdir"
        trace printf "removed directory '%s'\n" "$installroot/$pkgdir"
}

# Return true if recovery is required, else false
# If a partial install is found that can be discarded without effect
# then remove the partial install and return false
recovery_required() {
        local entry rlog
        declare -a ipkg args log
        declare -g partial_install

        try readarray -t ipkg \
                < <(try find "$installroot" -maxdepth 1 -type d -name '.i_*' -printf '%P\n')

        case "${#ipkg[@]}" in
                0) return 1 ;;
                1) partial_install="${ipkg[0]}" ;;
                *) fail "multiple partial installations found, manual intervention required" ;;
        esac

        # if log is in live package then recovery is required
        [[ ! -f "$installroot/${partial_install:3}/.spkg/recovery_log" ]] || 
                return 0

        rlog="$installroot/$partial_install/.spkg/recovery_log"
        # if we have a log then check if it sufficient for recovery
        if [[ -f "$rlog" ]]; then
                try readarray -t log < "$rlog"
                die_if $? "reading $rlog"

                # Log must have at least one arg and end with ===
                [[ 2 > ${#log[@]} || '===' != "${log[-1]}" ]] || return 0
        fi

        # No, or insufficient, log info so remove partial_install and return false
        try rm -r "$installroot/$partial_install"
        unset -v partial_install
        return 1
}


# Command functions

# Options:
#   -c run test checks after build
#   -b build only (don't package files)
#   -p package previously built files to package repository
# Args: single package spec
build_command() {
        require 'build'

        local pkgspec=$1
        local opt_check=0
        local opt_build_only=0
        local opt_package_only=0

        parse_pkgspec "$pkgspec" || fail "invalid package spec $pkgspec"

        log "[Command]" "spkg build $*"

        while getopts ":cbp" opt; do
                case $opt in
                        c ) opt_check=1 ;; 
                        b ) opt_build_only=1 ;;
                        p ) opt_package_only=1 ;;
                        * ) fail "invalid option: $OPTARG" ;;
                esac
        done
        shift $(( OPTIND - 1 ))

        (( ( $opt_build_only || $opt_check ) && $opt_package_only )) &&
                        fail "cannot use option -p with -b or -c"


        build_pkg "$pkgspec" $opt_check $opt_build_only $opt_package_only

        if (( $opt_build_only )); then
                info "Package built $pkgspec"
        else
                info "Package added $pkgspec"
        fi
}

install_command() {
        require 'install'

        declare -a pkgs
        local p n f opt_yes opt_force

        has_permission || fail "insufficient privilege to install packages" 

        log "[Command]" "spkg install $*"

        while getopts ":fy" opt; do
                case $opt in
                        f ) opt_force=1 ;; 
                        y ) opt_yes=1 ;;
                        * ) fail "invalid option: $OPTARG" ;;
                esac
        done
        shift $(( OPTIND - 1 ))

        try cd "$pkgroot"

        if (( $# == 0 )); then
                # Reverse sort by name and version, take first (most recent version)
                # for each package name, ignoring any that are already installed
                f=''
                # shellcheck disable=SC2035 # this does what is required
                for p in $(versort -r *-$pkgsuffix); do
                        p="${p%-$pkgsuffix}"
                        n="${p%-*-*}"
                        if [[ $f != "$n" ]]; then
                                f=$n
                                if ! is_installed "$p"; then
                                        pkgs+=("$p")
                                fi
                        fi
                done

        else
                for p; do
                        if parse_pkgspec "$p"; then
                                if is_installed "$p"; then
                                        if [[ $opt_force ]]; then
                                                # forceable reinstall
                                                # no idea of the state things are in
                                                # so remove package installdir and try again
                                                try rm -r "${installroot:?}/${p%-*-*}"
                                        else
                                                fail "package $p is already installed, use install -f to force reinstall"
                                        fi
                                fi
                                pkgs+=("$p")
                        else
                                p=$(latest_pkg "$p")
                                if [[ $p ]] && ! is_installed "$p"; then
                                        pkgs+=("$p")
                                fi
                        fi
                done
        fi

        if (( ${#pkgs[@]} == 0 )); then
                info "No packages to upgrade/install"
        elif [[ $opt_yes ]] ||
                        confirm_pkgs_nolog "Install [Y/n]? " "y" "${pkgs[@]}"; then
                for p in "${pkgs[@]}"; do
                        install_pkg_command "$p"
                done
                info "${#pkgs[@]} packages upgraded/installed"
        fi
}

uninstall_command() {
        require 'uninstall'

        declare -a pkgs
        local p opt_yes

        has_permission || fail "insufficient privilege to uninstall packages" 

        log "[Command]" "spkg uninstall $*"

        while getopts ":y" opt; do
                case $opt in
                        y ) opt_yes=1 ;;
                        * ) fail "invalid option: $OPTARG" ;;
                esac
        done
        shift $(( OPTIND - 1 ))

        for p; do
                if parse_pkgspec "$p"; then
                        if is_installed "$p"; then
                                pkgs+=( "$p" )
                        else
                                fail "package is not installed $p"
                        fi
                elif [[ -d "$installroot/$p" ]]; then
                        p="$(try cat "$installroot/$p/.spkg/pkgspec")"
                        pkgs+=( "$p" )
                fi
        done

        if (( ${#pkgs[@]} == 0 )); then
                info 'No packages to uninstall'
        elif [[ $opt_yes ]] ||
                        confirm_pkgs_nolog 'Uninstall [Y/n]? ' 'y' "${pkgs[@]}"; then
                for p in "${pkgs[@]}"; do
                        uninstall_pkg_command "$p"
                done
                info "${#pkgs[@]} packages uninstalled"
        fi
}

list_command() {
        require 'list'

        declare -a all_types
        local opt opt_archive opt_builddir opt_installed opt_packaged types
        
        while getopts ":aipd" opt; do
                case $opt in
                        a ) opt_archive=1 ;;
                        d ) opt_builddir=4 ;;
                        i ) opt_installed=1 ;;
                        p ) opt_packaged=2 ;;
                        * ) fail "Invalid option: $OPTARG" ;;
                esac
        done
        shift $(( OPTIND - 1 ))

        all_types=( '' i p d ip d id pd ipd )
        types="${all_types[opt_installed + opt_packaged + opt_builddir]}"
        if (( $opt_archive )); then
                list_archive_command "$types" "$@"
        else
                list_pkg_command "$types" "$@"
        fi
}

help_command() {
        require 'help'
        show_help
}

recover_command() {
        require 'install'

        # partial_install set by have_partial_install and
        # is the only way for recovery to be attempted
        declare -g partial_install

        has_permission || fail "insufficient privilege to recover installation" 

        log "[Command]" "spkg recover $*"

        if recover_pkg_command "$partial_install"; then
                info 'Package installation recovery complete'
        else
                info 'Package installation rolled back, please re-install'
        fi
}

run_command() {
        local cmd=$1

        (( $# == 0 )) || shift

        case "$cmd" in
                build )          build_command "$@" ;;
                install )        install_command "$@" ;;
                uninstall )      uninstall_command "$@" ;;
                list )           list_command "$@" ;;
                -v|--version )   try echo "${0##*/} $version" ;;
                -h|--help|help ) help_command ;;
                "" )             usage ;;
                * )              fail "invalid command: $cmd" ;;
        esac
}

run_recover_command() {
        local cmd=$1

        if [[ $cmd == "recover" && $# == 1 ]]; then
                recover_command
                return
        fi

        fail "$(try cat << EOF
partial package installation detected, run:

${0##*/} recover

to complete the installation
EOF
        )"
}

# Copies of stdout/stderr for package confirm and confirm_package
exec {stdoutfd}>&1
exec {stderrfd}>&2

libdir=/var/lib/spkg
logdir=/var/log/spkg
requirepath=/usr/share/spkg/lib
installdir=/spkg
srccache=/sources
pkgsuffix="x86_64.spkg.tar.gz"

if [[ -f "$prefix/etc/spkg.conf" ]]; then
        source_file "$prefix/etc/spkg.conf"
fi

libroot=${sysroot}$libdir
pkgroot=$libroot/pkg
oldroot=$libroot/old
buildroot=$libroot/build
buildfile=SPKGBUILD

logroot=${sysroot}$logdir
requirepath="$(prefix_path "$requirepath")"

installroot=${sysroot}$installdir
srcroot=${sysroot}$srccache

logfile=${logroot}/spkg.log
tracefile=${logroot}/trace.log
stdoutfile=${logroot}/stdout.log
stderrfile=${logroot}/stderr.log

try mkdir -p "$logroot"
try rm -f "$tracefile" "$stdoutfile" "$stderrfile"

if recovery_required; then
        cmd=run_recover_command
else
        cmd=run_command
fi

trap 'cleanup' EXIT

$cmd "$@" > >(tee $stdoutfile) 2> >(tee $stderrfile >&2)
