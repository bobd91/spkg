#!/bin/env bash

# Simple Package Manager

# TODO: improve error logging and failure behaviour

# TODO: confirm that pkgdirs are copied forward into new package

# TODO: check uninstall behaviour of merged/replaced packages

# TODO: testing

# TODO: lfs2spkg 

# shellcheck disable=SC2164 # we shadow cd to check for failure
# shellcheck disable=SC1090,SC1091 # we source lots of user defined files

# configure replaces SPKG_... values
sysroot=SPKG_with_sysroot
prefix=SPKG_prefix
version=SPKG_version

set -E
trap abort SIGUSR1
sigpid=$$

exec {stdout} >&1
exec {stderr} >&2

abort() {
        printf 'Aborting...\n' >&2
        exit 1
}

# Program failure
die() {
        local errno=$1
        local level=$2
        local where
        readarray -d ' ' -t where < <(caller $level)
        shift 2
        printf '%s => failed(%s) at %s:%s\n' \
                "$*" $errno "${where[2]:0:-1}" "${where[0]}" >&$errfd
        kill -s SIGUSR1 $sigpid
        exit 1
}

die_if() {
        (( $1 != 0 )) || return
        shift
        die $1 1 "$@"
}

# User error
fail() {
        echo "$@" >&$stderr
        kill -s SIGUSR1 $sigpid
        exit 1
}

# Try to run something, die if it fails
try() {
        "$@" || die $? 1 "$@"
}

# Names:
#
# Variable Names for package parts
# 
# pkgname: the name of the package, without version or release information
# pkgver: the version of a package
# pkgrel: the release of a pkgnv (allow security patching without pkgver change)
# pkgspec: <pkgname>-<pkgver>-<pkgrel>
#
#
# Variable Names for spkg directories
#
# libdir: /var/lib/spkg
# builddir: /var/lib/spkg/build
# pkgdir: /var/lib/spkg/pkg
# installdir: /spkg (can be changed in /etc/spkg.conf)
# srccachedir: /sources (can be changed in /etc/spkg.conf)
#
# sysroot: a directory root for the file system being managed
#          empty in final system, $LFS in a Linux from Scratch pre-chroot system
#
# libroot, buildroot, pkgroot, installroot: 
#       as with the dirs above but prefixed with sysroot
#
# Note: In install/uninstall functions $pkgdir is often used to refer to the
# directory where the package files are installed rather than /var/lib/spkg/pkg,
# the context is usually clear.
#
#
# Variable Names for package files
#
# pkgfile: a file from a package that will be symlinked
# userfile: a file from a package that will be copied
#
# installedfile: a pkgfile or userfile in installroot/<pkgname>/
# targetfile: a pkgfile in the package installdir/<pkgname>/
# linkfile: a pkgfile in the real file system, symlinked to a targetfile
# sysfile: a file in the real system, may be a linkfile or a userfile


info() {
        echo "$*"
        log "[Info]" "$@"
}

warn() {
        echo "Warning: $*"
        log "[Warning]" "$@" 
}

log() {
        echo "[$(date -Iseconds)] $*" >> "$logfile"
}

source_file() { 
        pushd . > /dev/null
        try source "$@"
        popd > /dev/null
}


require() {
        declare -gA require_done
        local lib
        for lib; do
                [[ ! ${require_done[$lib]} ]] || continue
                source_file "$requireroot/$lib.sh"
                require_done[$lib]=1
        done
}

has_permission() {
        [[ -w "$installroot" ]]
}

call_fn() {
        [[ "$(type -t "$1")" == function ]] || return
        try "$@"
}

parse_pkgspec() {
        [[ $1 =~ ^.+-([^-]+)-[0-9]+ ]]
}

pkgfiles() {
        local files
        shopt -s nullglob
        files=( "${1:?}"-[0-9][0-9\.-]* )
        shopt -u nullglob
        if (( ${#files[@]} )); then
                echo "${files[@]}"
        fi
}

# Print package spec of installed version of <package name>
installed_pkg() {
        local pkgname=${1:?}
        local pkgspec="$installroot/$pkgname/.spkg/pkgspec"

        if [[ -f $pkgspec ]]; then
                try cat "$pkgspec"
        fi
}

# Success if <package spec> is installed
is_installed() {
        local pkgspec=${1:?}
        local pkgname=${pkgspec%-*-*}

        [[ $pkgspec == "$(installed_pkg "$pkgname")" ]]
}

# Print package specs that match args sorted by name and version number
# If first argument is '-r' then reverse sort
versort() {
        local args='-bdv'

        # Using output of ls in scripts is problematic but we want to use version sorting
        # And package names shouldn't contain newlines and other odd characters
        if [[ $1 == '-r' ]]; then
                args+='r'
                shift
        fi

        try ls "$args" "$@" 2> /dev/null
}

# Print package spec of the <package name> with the highest version number
latest_pkg() {
        local pkgname=${1:?}
        local tars

        # Extract package spec from full path listing of tar files
        # Latest version will be sorted to the bottom

        try readarray tars < <(pkgfiles "$pkgroot/$pkgname")
        if (( ${#tars[@]} )); then
                versort "${tars[@]}" | 
                        try sed -e "s|/\([^/]\+/\)*\(.*\)\-$pkgsuffix|\2|" | 
                        try tail -n 1
        fi
}

confirm () {
        try read -p "$1" -n 1 -r
        try echo
        [[ ${REPLY,,} =~ ^(|"$2")$ ]]
}

confirm_pkgs() {
        local prompt=${1:?}
        local def=${2:?}
        shift 2

        try printf "Selected packages:\n\n"
        try printf "%s\n\n" "$*"
        confirm "$prompt" "$def"
}

# Options:
#   -c run test checks after build
#   -b build only (don't package files)
#   -p package previously built files to package repository
# Args: single package spec
build_command() {
        require 'build'

        local pkgspec=$1
        local opt_check=0
        local opt_build_only=0
        local opt_package_only=0

        parse_pkgspec "$pkgspec" || fail "invalid package spec $pkgspec"

        info "executing: spkg build $*"

        while getopts ":cbp" opt; do
                case $opt in
                        c ) opt_check=1 ;; 
                        b ) opt_build_only=1 ;;
                        p ) opt_package_only=1 ;;
                        * ) fail "invalid option: $OPTARG" ;;
                esac
        done
        shift $(( OPTIND - 1 ))

        if [[ ( $opt_build_only || $opt_check ) && $opt_package_only ]]; then
                fail "cannot use option -p with -b or -c"
        fi

        build_pkg "$pkgspec" $opt_check $opt_build_only $opt_package_only >&$outfd

        if (( $opt_build_only )); then
                info "package built $pkgspec"
        else
                ingo "package added $pkgspec"
        fi
}

# Print package specs of packages that install of <package spec> should remove
pkg_replaces() {
        local pkgspec=${1:?}
        local rep

        # we need to look at .spkg/replaces file before installing
        while read -r rep; do
                installed_pkg "$rep"
        done < <(try tar xOf "$pkgroot/$pkgspec-$pkgsuffix" "$pkgspec/.spkg/replaces")
}

install_command() {
        require 'install'

        declare -a pkgs
        local p n f opt_yes opt_force

        has_permission || fail "insufficient privilege to install packages" 

        while getopts ":fy" opt; do
                case $opt in
                        f ) opt_force=1 ;; 
                        y ) opt_yes=1 ;;
                        * ) fail "invalid option: $OPTARG" ;;
                esac
        done
        shift $(( OPTIND - 1 ))

        info "executing: spkg install $*"

        try cd "$pkgroot"

        if (( $# == 0 )); then
                # Reverse sort by name and version, take first (most recent version)
                # for each package name, ignoring any that are already installed
                f=''
                # shellcheck disable=SC2035 # this does what is required
                for p in $(versort -r *-$pkgsuffix); do
                        p=${p%-"$pkgsuffix"}
                        n=${p%-*-*}
                        if [[ $f != "$n" ]]; then
                                f=$n
                                if ! is_installed "$p"; then
                                        pkgs+=("$p")
                                fi
                        fi
                done

        else
                for p; do
                        if parse_pkgspec "$p"; then
                                if is_installed "$p"; then
                                        if [[ $opt_force ]]; then
                                                # forceable reinstall
                                                # no idea of the state things are in
                                                # so remove package installdir and try again
                                                try rm -r "${installroot:?}/$p"
                                        else
                                                fail "package $p is already installed, use install -f to force reinstall"
                                        fi
                                fi
                                pkgs+=("$p")
                        else
                                p=$(latest_pkg "$p")
                                if [[ $p ]] && ! is_installed "$p"; then
                                        pkgs+=("$p")
                                fi
                        fi
                done
        fi

        if (( ${#pkgs[@]} == 0 )); then
                info "no packages to upgrade/install"
        elif [[ $opt_yes ]] ||
                        confirm_pkgs "Install [Y/n]? " "y" "${pkgs[@]}"; then
                for p in "${pkgs[@]}"; do
                        info "installing: $p"
                        install_pkg_command "$p"
                done
                info "${#pkgs[@]} packages upgraded/installed"
        fi
}

uninstall_command() {
        require 'uninstall'

        declare -a pkgs
        local p opt_yes

        has_permission || fail "insufficient privilege to uninstall packages" 

        while getopts ":y" opt; do
                case $opt in
                        y ) opt_yes=1 ;;
                        * ) fail "invalid option: $OPTARG" ;;
                esac
        done
        shift $(( OPTIND - 1 ))

        info "executing: spkg uninstall $*"

        for p; do
                if parse_pkgspec "$p"; then
                        if is_installed "$p"; then
                                pkgs+=("$p")
                        else
                                fail "package is not installed $pkg"
                        fi
                else 
                        # should only ever be 0 or 1
                        try read -r -d '' p < <(try find $installroot -name "$p-*" -print0)
                        if [[ $p ]]; then
                                pkgs+=( "${p##*/}" )
                        fi
                fi
        done

        if (( ${#pkgs[@]} == 0 )); then
                info 'no packages to uninstall'
        elif [[ $opt_yes ]] ||
                        confirm_pkgs 'Uninstall [Y/n]? ' 'y' "${pkgs[@]}"; then
                for p in "${pkgs[@]}"; do
                        info "uninstalling: $p"
                        uninstall_pkg_command "$p"
                done
                info "${#pkgs[@]} packages uninstalled"
        fi
}

list_command() {
        require 'list'

        local opt opt_dir
        
        while getopts ":d" opt; do
                case $opt in
                        d ) opt_dir=1 ;;
                        * ) fail "Invalid option: $OPTARG" ;;
                esac
        done
        shift $(( OPTIND - 1 ))

        if [[ $opt_dir ]]; then
                list_dir_command "$@"
        else
                list_pkg_command "$@"
        fi
}

usage() {
        echo "Usage: $(basename "$0") command arg"
        echo "       $(basename "$0") --help"
}

help_command() {
        require 'help'
        show_help
}

have_partial_install() {
        declare -a ipkg
        try readarray -t ipkg < <(try find "$installroot" -maxdepth 1 -type d -name '.i_*' -printf '%P\n')
        case "${#ipkg[@]}" in
                0) return 1 ;;
                1) partial_install="${ipkg[0]}" ; return ;;
                *) fail "Multiple partial installations found, manual intervention required" ;;
        esac
}

recover_command() {
        require 'install'

        # partial_install set by have_partial_install and
        # is the only way for recovery to be attempted
        if recover_pkg_command "$partial_install"; then
                info 'Package installation recovery complete'
        else
                info 'Package installation rolled back, please re-install'
        fi
}

run_command() {
        local cmd=$1

        (( $# == 0 )) || shift

        case "$cmd" in
                build )          build_command "$@" ;;
                install )        install_command "$@" ;;
                uninstall )      uninstall_command "$@" ;;
                list )           list_command "$@" ;;
                -v|--version )   info "${0##*/} $version" ;;
                -h|--help|help ) help_command ;;
                "" )             usage ;;
                * )              fail "invalid command: $cmd" ;;
        esac
}

run_recover_command() {
        local cmd=$1

        [[ $cmd == "recover" && $# == 1 ]] && recover_command

        fail << EOF
partial package installation detected, run:

${0##*/} recover

to complete the installation
EOF
}

libdir=/var/lib/spkg
logdir=/var/log/spkg
requiredir=/usr/share/spkg/lib
installdir=/spkg
srccache=/sources
pkgsuffix="x86_64.spkg.tar.gz"

if [[ -f "$prefix/etc/spkg.conf" ]]; then
        source_file "$prefix/etc/spkg.conf"
fi

libroot=${sysroot}$libdir
pkgroot=$libroot/pkg
oldroot=$libroot/old
buildroot=$libroot/build
buildfile=SPKGBUILD

logroot=${sysroot}$logdir
requireroot=${sysroot}$requiredir

installroot=${sysroot}$installdir
srcroot=${sysroot}$srccache

logfile=${logroot}/spkg.log
tracefile=${logroot}/trace.log

try mkdir -p "${logfile%/*}"

if have_partial_install; then
        cmd=run_recover_command
else
        cmd=run_command
fi

$cmd "$@" > >(tee $outlog) 2> >(tee $errlog >&2)
