# Simple Package Manager
# Build File

pkgname=SPKG_name
pkgver=SPKG_version
pkgrel=SPKG_release

sources=(SPKG_source)
md5sums=(SPKG_md5)

build() {
        ./configure \
                --is-spkgbuild=yes \
                --srccache="SPKG_srccache" \
                --installdir="SPKG_installdir"
}

package() {
        make DESTDIR="$pkgdir" install

        # spkg bash completion
        # Move to bash completions if installed, otherwise leave in /usr/share/
        if [[ -d $sysroot/usr/share/bash-completion/completions ]]; then
                mkdir -p "$pkgdir/usr/share/bash-completion/conpletions"
                mv "$pkgdir/usr/share/spkg/spkg.bash" \
                   "$pkgdir/usr/share/bash-completion/completions/spkg"
                rmdir "$pkgdir/usr/share/spkg"
        fi
}

